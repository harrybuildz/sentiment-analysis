#!/usr/bin/env bash
# =============================================================================
# pre-commit secret scanner
# =============================================================================
# Activates scanning of staged files for common API-key patterns before every
# commit. Install by running, from the repo root:
#
#     git config core.hooksPath .githooks
#     chmod +x .githooks/pre-commit
#
# This is a belt-and-suspenders defense in addition to `.gitignore`. If you
# accidentally stage a `.env` or paste a key into a tracked file, this hook
# will refuse the commit with a clear error pointing at the offending file.
# =============================================================================
set -euo pipefail

# Colors (disabled if not a TTY)
if [ -t 1 ]; then
    RED=$(printf '\033[0;31m')
    YELLOW=$(printf '\033[0;33m')
    GREEN=$(printf '\033[0;32m')
    RESET=$(printf '\033[0m')
else
    RED=''; YELLOW=''; GREEN=''; RESET=''
fi

# Gather files staged for commit. Skip deletions.
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_files" ]; then
    exit 0
fi

# --- Rule 1: block any staged .env* file ----------------------------------
env_files=$(echo "$staged_files" | grep -E '(^|/)\.env($|\.|[^.])' || true)
if [ -n "$env_files" ]; then
    echo "${RED}✗ Refusing to commit: .env files should never be committed.${RESET}"
    echo "Offending files:"
    echo "$env_files" | sed 's/^/    /'
    echo ""
    echo "If this was an .env.example template, rename it and try again."
    echo "To bypass this hook (NOT recommended), use: git commit --no-verify"
    exit 1
fi

# --- Rule 2: scan staged diff for known key patterns ----------------------
# Patterns are grouped into "high confidence" (won't occur in normal code).
patterns=(
    # Anthropic
    'sk-ant-[a-zA-Z0-9_\-]{20,}'
    # OpenAI
    'sk-[a-zA-Z0-9]{40,}'
    # GitHub personal access token / fine-grained
    'gh[pousr]_[A-Za-z0-9]{36,}'
    # AWS access key ID
    'AKIA[0-9A-Z]{16}'
    # Google API key
    'AIza[0-9A-Za-z_\-]{35}'
    # Slack tokens
    'xox[baprs]-[A-Za-z0-9\-]{10,}'
    # Stripe
    'sk_live_[0-9a-zA-Z]{24,}'
    # Private key header
    '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
)

# Build the combined grep pattern (pipe-separated, escaping is handled by grep -E)
combined=""
for p in "${patterns[@]}"; do
    if [ -z "$combined" ]; then combined="$p"; else combined="$combined|$p"; fi
done

# Scan the staged diff (only added/changed lines, courtesy of --cached)
violations=$(git diff --cached --no-color -U0 | grep -nE "^\+" | grep -nE "$combined" || true)
if [ -n "$violations" ]; then
    echo "${RED}✗ Refusing to commit: potential secret detected in staged diff.${RESET}"
    echo ""
    echo "$violations" | sed 's/^/    /'
    echo ""
    echo "If this is a false positive (e.g., the string appears in test data),"
    echo "you can bypass with: ${YELLOW}git commit --no-verify${RESET}"
    exit 1
fi

# --- Rule 3: warn on suspicious variable assignments ----------------------
# Lines that look like NAME = "long-string" where NAME contains 'KEY', 'SECRET',
# 'TOKEN', or 'PASSWORD' and the value is non-empty and non-template.
suspicious=$(git diff --cached --no-color -U0 | grep -nE "^\+" | \
    grep -iE '(api_key|secret|token|password)\s*[:=]\s*["\x27][^"\x27<>{}\$]{12,}["\x27]' || true)
if [ -n "$suspicious" ]; then
    echo "${YELLOW}⚠ Warning: suspicious-looking assignment found in staged diff:${RESET}"
    echo ""
    echo "$suspicious" | sed 's/^/    /'
    echo ""
    echo "If that's a real secret, abort and move it to .env."
    echo "If it's safe (e.g., documentation or a placeholder), press Enter to continue or Ctrl-C to abort."
    if [ -t 0 ]; then
        read -r _
    fi
fi

echo "${GREEN}✓ pre-commit: no secrets detected${RESET}"
exit 0
